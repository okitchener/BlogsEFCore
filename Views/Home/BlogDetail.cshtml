@model PostViewModel

<div class="bg-primary m-1 p-1 text-white"><h4>@Model.blog.Name Details</h4></div>

@if (Model.Posts.Count() == 0)
{
  <p>There are no posts</p>
}
else
{
  <ul>
    @foreach (Post post in Model.Posts)
    {
      <li>
        @post.Title - @post.Content
        @if (User?.Identity?.IsAuthenticated ?? false)
        {
          if (User.IsInRole("blogs-moderate"))
          {
            <span> | </span><a asp-controller="Home" asp-action="DeletePost" asp-route-id="@post.PostId">Delete</a>
          }
        }
      </li>
    }
  </ul>
}

<hr />
<a asp-controller="Home" asp-action="Index">Home</a>
<span> | </span><a asp-controller="Home" asp-action="AddPost" asp-route-id="@Model.blog.BlogId">New Post</a>